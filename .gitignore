# YT Bookmark Cleaner - generated / local files

# Native host files generated by installer (machine-specific paths)
com.ytbookmark.ytdlp.json
native_host_launcher.bat

# Bundled or downloaded binaries
ffmpeg.exe
bin/ffmpeg.exe
bin/ffprobe.exe
bin/ffplay.exe
*.exe

# Python cache / virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
*.egg-info/

# Logs / diagnostics
*.log
logs/
diagnostic*.txt
diagnose*.txt
repair*.txt
install-report*.txt

# Local user data / test imports
file/
bookmarks/
*.html
*.csv
*.txt

# OS/editor junk
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# Archives / release builds
*.zip
*.7z
*.rar
*.tar
*.tar.gz
dist/
build/
release/

# Node tooling, only if added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
