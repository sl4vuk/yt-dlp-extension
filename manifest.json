{
  "manifest_version": 3,
  "name": "YT Bookmark Cleaner",
  "version": "2.6",
  "description": "YouTube bookmark manager, sync & downloader with yt-dlp",

  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "nativeMessaging",
    "sidePanel",
    "clipboardRead",
    "cookies"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "YT Bookmark Cleaner",
    "default_popup": "ui.html"
  },

  "side_panel": {
    "default_path": "ui.html?mode=sidebar"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Activate the extension"
    },
    "quick-download": {
      "suggested_key": { "default": "Alt+F" },
      "description": "Download current YouTube / YT Music video with yt-dlp"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["cleaner.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "https://accounts.google.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["ui.html", "settings.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
