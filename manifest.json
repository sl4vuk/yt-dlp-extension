{
  "manifest_version": 3,
  "name": "YT Bookmark Cleaner",
  "version": "2.1",
  "description": "YouTube bookmark manager, sync & downloader with yt-dlp",

  "permissions": [
    "bookmarks",
    "storage",
    "windows",
    "tabs",
    "nativeMessaging"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "YT Bookmark Cleaner",
    "default_popup": "ui.html"
  },

  "commands": {
    "toggle-ui": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Open YT Bookmark Cleaner"
    },
    "auto-like": {
      "suggested_key": { "default": "Ctrl+Shift+L" },
      "description": "Auto-like current YouTube video (use Ctrl+D on page for like+bookmark)"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["cleaner.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["ui.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
